+#include <zephyr/drivers/gpio.h>
+static const struct gpio_dt_spec btn1 = GPIO_DT_SPEC_GET(DT_ALIAS(sw0), gpios);
+static const struct gpio_dt_spec btn2 = GPIO_DT_SPEC_GET(DT_ALIAS(sw1), gpios);
+static int get_image_num_from_button(void)
+{
+	int img_num;
+
+	if (!gpio_is_ready_dt(&btn1) || !gpio_is_ready_dt(&btn2)) {
+		printk("get_image_num_from_button: GPIO not ready\n");
+		return -1;
+	}
+	gpio_pin_configure_dt(&btn1, GPIO_INPUT);
+	gpio_pin_configure_dt(&btn2, GPIO_INPUT);
+
+	LOG_INF("Choose BTN1 = bank1, BTN2 = bank0");
+	while (1) {
+		if (gpio_pin_get_dt(&btn1) > 0) {
+			img_num = 0;
+			printk("get_image_num_from_button: BTN1 pressed -> bank1\n");
+			break;
+		}
+
+		if (gpio_pin_get_dt(&btn2) > 0) {
+			img_num = 1;
+			printk("get_image_num_from_button: BTN2 pressed -> bank0\n");
+			break;
+		}
+
+		k_msleep(10);
+	}
+	LOG_INF("img_num: %d", img_num);
+	return img_num;
+}
