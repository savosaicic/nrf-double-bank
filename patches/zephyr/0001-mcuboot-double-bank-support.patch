+bool boot_is_img_confirmed_multi(int image_index)
+{
+	struct boot_swap_state state;
+	int rc;
+
+#if USE_PARTITION_MANAGER
+	static const uint8_t primary_ids[] = {
+		PM_MCUBOOT_PRIMARY_ID,
+#ifdef PM_MCUBOOT_PRIMARY_1_ID
+		PM_MCUBOOT_PRIMARY_1_ID,
+#endif
+#ifdef PM_MCUBOOT_PRIMARY_2_ID
+		PM_MCUBOOT_PRIMARY_2_ID,
+#endif
+	};
+
+	if (image_index < 0 || image_index >= (int)ARRAY_SIZE(primary_ids)) {
+		return false;
+	}
+
+	rc = boot_read_swap_state_by_id(primary_ids[image_index], &state);
+#else
+	/* Non-PM: only image 0 supported, fall back to existing behaviour */
+	if (image_index != 0) {
+		return false;
+	}
+	const struct flash_area *fa;
+
+	rc = flash_area_open(ACTIVE_SLOT_FLASH_AREA_ID, &fa);
+	if (rc) {
+		return false;
+	}
+	rc = boot_read_swap_state(fa, &state);
+	flash_area_close(fa);
+#endif
+
+	if (rc != 0) {
+		return false;
+	}
+
+	if (state.magic == BOOT_MAGIC_UNSET) {
+		return true;
+	}
+
+	return state.image_ok == BOOT_FLAG_SET;
+}
